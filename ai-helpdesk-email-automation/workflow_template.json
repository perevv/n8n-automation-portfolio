    {
      "parameters": {
        "html": "<!DOCTYPE html>\n<html lang=\"uk\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Підтримка — Coffee & Code</title>\n  <style>\n    body {\n      font-family: system-ui, -apple-system, sans-serif;\n      max-width: 580px;\n      margin: 40px auto;\n      line-height: 1.6;\n      color: #1a1a1a;\n      background: #fdfdfd;\n    }\n    h1 {\n      text-align: center;\n      color: #c2410c;\n      margin-bottom: 8px;\n      font-size: 1.9rem;\n    }\n    .subtitle {\n      text-align: center;\n      color: #666;\n      margin-bottom: 32px;\n      font-size: 0.95rem;\n    }\n    .card {\n      background: white;\n      border-radius: 10px;\n      box-shadow: 0 2px 12px rgba(0,0,0,0.08);\n      padding: 24px;\n      margin-bottom: 24px;\n    }\n    .card h2 {\n      margin: 0 0 12px 0;\n      color: #c2410c;\n      font-size: 1.28rem;\n    }\n    .contact-item {\n      margin: 14px 0;\n      font-size: 1.02rem;\n    }\n    .label {\n      color: #555;\n      font-weight: 500;\n      display: inline-block;\n      width: 110px;\n      min-width: 110px;\n    }\n    .value {\n      color: #1a1a1a;\n    }\n    .value a {\n      color: #c2410c;\n      text-decoration: none;\n      font-weight: 600;\n    }\n    .value a:hover {\n      text-decoration: underline;\n    }\n    .hours {\n      font-size: 0.95rem;\n      color: #555;\n      margin-top: 4px;\n    }\n    .social {\n      margin-top: 28px;\n      text-align: center;\n    }\n    .social a {\n      margin: 0 12px;\n      color: #c2410c;\n      font-size: 1.1rem;\n      text-decoration: none;\n    }\n    .note {\n      text-align: center;\n      color: #777;\n      font-size: 0.85rem;\n      margin-top: 32px;\n    }\n  </style>\n</head>\n<body>\n\n  <h1>Підтримка</h1>\n  <div class=\"subtitle\">Coffee & Code — завжди на зв’язку</div>\n\n  <div class=\"card\">\n    <h2>Швидка підтримка</h2>\n    <div class=\"contact-item\">\n      <span class=\"label\">Телефон:</span>\n      <span class=\"value\"><a href=\"tel:+380671234567\">+38 (067) 123-45-67</a></span>\n    </div>\n    <div class=\"contact-item\">\n      <span class=\"label\">Telegram:</span>\n      <span class=\"value\"><a href=\"https://t.me/coffeecode_support\">@coffeecode_support</a></span>\n    </div>\n    <div class=\"contact-item\">\n      <span class=\"label\">Email:</span>\n      <span class=\"value\"><a href=\"mailto:help@coffeecode.ua\">help@coffeecode.ua</a></span>\n    </div>\n    <div class=\"contact-item\">\n      <span class=\"label\">Час роботи:</span>\n      <span class=\"value\">Пн–Нд 8:00 – 22:00</span>\n      <div class=\"hours\">Відповідь у чаті — до 10 хвилин у робочий час</div>\n    </div>\n  </div>\n\n  <div class=\"card\">\n    <h2>Адреси закладів</h2>\n    <div class=\"contact-item\">\n      <span class=\"label\">Київ 1:</span>\n      <span class=\"value\">вул. Велика Житомирська, 22</span>\n    </div>\n    <div class=\"contact-item\">\n      <span class=\"label\">Київ 2:</span>\n      <span class=\"value\">вул. Саксаганського, 99</span>\n    </div>\n    <div class=\"contact-item\">\n      <span class=\"label\">Львів:</span>\n      <span class=\"value\">пл. Ринок, 14</span>\n    </div>\n  </div>\n\n  <div class=\"social\">\n    <a href=\"https://t.me/coffeecode\">Telegram</a> •\n    <a href=\"https://instagram.com/coffeecode\">Instagram</a> •\n    <a href=\"https://facebook.com/coffeecode\">Facebook</a>\n  </div>\n\n  <div class=\"note\">Ми відповідаємо максимально швидко.<br>Дякуємо, що ви з нами! ☕</div>\n\n</body>\n</html>"
      },
