    {
      "parameters": {
        "jsCode": "const source = $json.body.source;\n\nconst priority = source === 'facebook' || source === 'instagram'\n? \"Високий\"\n: source === 'website'\n? \"Середній\"\n: \"Низький\";\n\nconst priority_telegram = source === \"facebook\" || source === \"instagram\"\n? \"🔥 Високий\"\n: source === 'website'\n? \"⚡ Середній\"\n: \"📩 Низький\";\n\nreturn {\n  name: $json.body.name,\n  email: $json.body.email,\n  phone: $json.body.phone,\n  source: $json.body.source,\n  message: $json.body.message,\n  priority: priority,\n  priotiryTelegram: priority_telegram,\n  timestamp: new Date().toISOString(),\n  timestampTelegram: new Date().toLocaleString('uk-UA',{\n    day: '2-digit',\n    month: '2-digit',\n    year: 'numeric',\n    hour: '2-digit',\n    minute: '2-digit',\n    timeZone: 'Europe/Kyiv'\n  })\n}"
      },
